{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AMark",
  "version": "0.1.1",
  "identifier": "ai.marswave.amark",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "vp dev",
    "beforeBuildCommand": "vp build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "AMark",
        "width": 960,
        "height": 720,
        "minWidth": 600,
        "minHeight": 400,
        "decorations": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "deb",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "name": "AMark.Markdown",
        "ext": ["md", "markdown", "mdown", "mkd"],
        "description": "Markdown Document",
        "role": "Editor"
      }
    ],
    "resources": ["icons/amark_markdown_icon.ico"],
    "windows": {
      "nsis": {
        "installerHooks": "windows/hooks.nsi"
      }
    }
  }
}
