# 默认：自动识别文本文件，仓库内统一使用 LF 换行符
* text=auto eol=lf

# 显式声明源码 / 配置为文本（始终 LF）
*.ts     text eol=lf
*.tsx    text eol=lf
*.js     text eol=lf
*.jsx    text eol=lf
*.rs     text eol=lf
*.json   text eol=lf
*.toml   text eol=lf
*.yaml   text eol=lf
*.yml    text eol=lf
*.css    text eol=lf
*.html   text eol=lf
*.md     text eol=lf
*.xml    text eol=lf
*.lock   text eol=lf
.gitignore     text eol=lf
.gitattributes text eol=lf
LICENSE        text eol=lf

# 二进制文件：禁止任何换行符 / 文本转换
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.icns binary
*.woff  binary
*.woff2 binary
*.ttf   binary
*.otf   binary
